<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block sensitive files
    <FilesMatch "\.(env|config|sql|log|ini|example)$">
        Require all denied
    </FilesMatch>

    # Disable directory listing
    Options -Indexes

    # ----------------------------------------
    # Serve existing files/directories normally
    # ----------------------------------------
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # API Routes
    RewriteRule ^api/(.*)$ core-handler?action=$1 [QSA,L]

    # Extension-less PHP pages
    RewriteRule ^(.+)$ $1.php [QSA,L]
</IfModule>